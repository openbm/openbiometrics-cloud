  <!-- Tab switching script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('#code-tabs button');
      const panels = {
        nodejs: document.getElementById('panel-nodejs'),
        python: document.getElementById('panel-python'),
        curl: document.getElementById('panel-curl'),
      };

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-tab');

          // Update tab styles
          tabs.forEach(t => {
            t.classList.remove('bg-white/10', 'text-white');
            t.classList.add('text-gray-400');
          });
          tab.classList.add('bg-white/10', 'text-white');
          tab.classList.remove('text-gray-400');

          // Show/hide panels
          Object.entries(panels).forEach(([key, panel]) => {
            if (panel) {
              panel.classList.toggle('hidden', key !== target);
            }
          });
        });
      });
    });
  </script>
